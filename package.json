{
  "name": "valundsab-se",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "serve": "bun scripts/serve.mjs",
    "check:html": "html-validate 'apps/web/**/*.html'",
    "check:css": "stylelint 'apps/web/**/*.css' --allow-empty-input",
    "check:js": "eslint .",
    "check:format": "prettier --check .",
    "check:hygiene": "bun scripts/check-source-hygiene.mjs",
    "check": "bun run check:html && bun run check:css && bun run check:js && bun run check:format && bun run check:hygiene && bun run check:security",
    "test": "playwright test",
    "check:release": "bun scripts/check-release.mjs",
    "audit": "bun scripts/run-audit.mjs",
    "check:security": "bun scripts/check-security.mjs",
    "test:security": "playwright test tests/security.spec.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.56.0",
    "eslint": "^10.7.0",
    "html-validate": "^11.5.6",
    "playwright": "1.56.0",
    "prettier": "^3.9.6",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0"
  }
}
